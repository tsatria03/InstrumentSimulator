class recorder
{
    bool recording = false;
    bool playing   = false;
    bool suppress_recording = false;
    dictionary record;
    int counter = 0;
    timer recordtimer;
    string recordings_dir = "data/recordings/";
    string recordings_key = "SA97K3Wb2galMsyqvX53BoAX9xLrR4eFbMWetCK4JUkSmpBTeyFE7qgsrwNPmqg8tVGJyC9oBG3MsdTGHLJYYAc8jviof8zjgk8mmtpeFwnzQN5Sfp0H3e2owft7F0xHETIPa1NsBH29m70ta8QTGhi5KdtKipSHtLxMUNSrxdAHy1FdiJpMFdcmrqjpMcckkjCUw9Yq7V9pQnLU7FJ2fPNNC5WZvG7xCjJYcMF9Px2G";
bool is_playing()
{
    return playing;
}
bool is_recording()
{
    return recording;
}
    void recordcheck()
    {
        if (!is_recording() && !is_playing() && alt_is_down() && key_pressed(KEY_L))
            load();
        if (!is_recording() && !is_playing() && alt_is_down() && key_pressed(KEY_S))
            save();
        if (!is_playing() && alt_is_down() && key_pressed(KEY_P))
        {
            if (record.get_size() <= 0)
            {
                speak("Nothing recorded");
                return;
            }
            recording = false;
            playing = true;
            speak("playing");
            play();
        }
        if (!is_recording() && alt_is_down() && key_pressed(KEY_R))
        {
            for (uint i = 3; i >= 1; i--)
            {
                speak("" + i + ",");
                wait(1000);
                if (i == 1) break;
            }
p.play_stationary("sounds/misc/pi2.ogg", false);
            speak("recording!");
            recording = true;
            playing = false;
            recordtimer.restart();
            counter = 0;
            record.delete_all();
        }
        if (is_recording() && alt_is_down() && key_pressed(KEY_RETURN))
        {
            speak("recording stopped");
            recording = false;
        }
    }
    void record_action(const string &in key)
    {
        if (!is_recording() || suppress_recording)
            return;
        counter++;
        int el = recordtimer.elapsed;
        recordtimer.restart();
        record.set("" + counter, "" + el + ":" + key);
    }
    void play()
    {
        suppress_recording = true;
        for (int i = 1; i <= counter; i++)
        {
            string info;
            if (!record.get("" + i, info))
                continue;
            string[] parts = string_split(info, ":", false);
            if (parts.length() < 2)
                continue;
            int delay_ms = string_to_int(parts[0]);
            string action_key = parts[1];
            recordtimer.restart();
            bool breakout = false;
            while (recordtimer.elapsed < delay_ms)
            {
                wait(5);
if (is_playing() && (key_pressed(KEY_RETURN) || key_pressed(KEY_R)))
                {
                    p.destroy_all();
                    speak("stopped");
                    breakout = true;
                    break;
                }
            }
            if (breakout)
                break;
            p.play_stationary(action_key, false);
        }
        suppress_recording = false;
        playing = false;
    }
    void save()
    {
        if (record.get_size() <= 0)
        {
            alert("Error", "Nothing to save. Please record something first.");
            return;
        }
        if (!directory_exists(recordings_dir))
            directory_create(recordings_dir);
        string fn = input_box("game recorder", "please type a name for this recording");
        if (fn == "")
            return;
        file savefile;
        savefile.open(recordings_dir + fn + ".rec", "wb");
        savefile.write(string_encrypt(serialize(record), recordings_key));
        savefile.close();
        speak("saved");
    }
    void load()
    {
        record.delete_all();
        counter = 0;
        string fn = loadfilesmenu("Please select a recording to load", recordings_dir, ".rec");
        if (fn == "0")
        {
            alert("Error", "No recordings found");
            return;
        }
        if (fn == "")
            return;
        file loadfile;
        loadfile.open(recordings_dir + fn, "rb");
        record = deserialize(string_decrypt(loadfile.read(), recordings_key));
        loadfile.close();
        counter = int(record.get_size());
        speak("loaded");
    }
}
